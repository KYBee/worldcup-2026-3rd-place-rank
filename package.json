{
  "name": "3rd-place-calculator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --test",
    "format": "prettier --check \"src/**/*.{ts,css}\" \"*.{json,js,ts,html}\"",
    "format:write": "prettier --write \"src/**/*.{ts,css}\" \"*.{json,js,ts,html}\"",
    "status": "node scripts/status.mjs",
    "status:check": "node scripts/status.mjs --check",
    "verify": "node scripts/verify.mjs",
    "verify:check": "node scripts/verify.mjs --check",
    "gate": "npm run status:check && npm run verify:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.43.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
